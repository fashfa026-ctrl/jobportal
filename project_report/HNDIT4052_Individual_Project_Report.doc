      <td class='bold' style='color:green;'>PASS</td>
    </tr>
    <tr>
      <td class='bold'>TC_05</td>
      <td>Resume Upload</td>
      <td>Select PDF file (5MB)</td>
      <td>Uploaded to uploads folder, path saved to user</td>
