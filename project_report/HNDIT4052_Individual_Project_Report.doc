    </tr>
    <tr>
      <td class='bold'>TC_06</td>
      <td>Job Application</td>
      <td>Seeker clicks Apply Now</td>
      <td>Application document created, applicant list increments</td>
      <td class='bold' style='color:green;'>PASS</td>
    </tr>
